{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "packages/cli": {
      "entry": [
        "src/cli.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/create-ssot-app": {
      "entry": [
        "src/index.ts",
        "src/templates/**/*.ts",
        "src/presets/**/*.ts",
        "src/factories/**/*.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/gen": {
      "entry": [
        "src/generators/**/*.ts",
        "src/plugins/**/*.ts",
        "src/templates/**/*",
        "src/pipeline/hooks/**/*.ts",
        "src/pipeline/phases/**/*.ts",
        "src/dependencies/**/*.ts"
      ],
      "project": [
        "src/**/*.ts",
        "src/**/*.js",
        "src/**/*.css"
      ]
    }
  },
  "ignore": [
    "**/__tests__/**",
    "**/*.test.ts",
    "**/dist/**",
    "generated/**",
    "examples/**",
    "websites/**",
    "templates-default/**",
    "scripts/**",
    "**/node_modules/**"
  ],
  "ignoreBinaries": [
    "test:validate"
  ]
}
